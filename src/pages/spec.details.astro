---
import Layout from "../layouts/Layout.astro";

import "../css/custom.css";

import Buttons from "../components/Buttons_nav.astro";
import Banner from "../components/Banner_read_more.astro";
---

<Layout>

<main>
<!--   Div til at indsætte billede-link fra Superbase af område. Billede 1 af 2 -->
  <div>
    <img src="/src/img/sandy_beach.webp" alt="" class="img_mobile-1"> 
</div>

 <Buttons />

<!--  Julie indsætter Superbase elementer --> 


 <h1>Naturområde overskrift - Superbase</h1>

<section class="desktop-section">
<!--  Collage af 2 billeder, der kun vises i desktop, indsæt img link 1 og 2-->
  <div class="collage-wrapper">
     <img src="/src/img/sandy_beach_coastline.webp" alt="" class="detail-img1">
     <img src="/src/img/sandy_beach.webp" alt="" class="detail-img2">
  </div>

    
  <div class="nature-text">
    <h2>Underoverskrift - Supabase</h2>
    <p>Tekst hentes gennem API om specifikt område. 

      Lorem ipsum dolor sit amet consectetur adipisicing elit. 
      Consequuntur, deserunt placeat neque esse excepturi aliquid 
      eveniet tempora temporibus quis reiciendis sunt nam. 
      Totam excepturi sequi ullam distinctio necessitatibus dignissimos delectus.</p>
  </div>

</section>


  <!--   Div til at indsætte billede-link fra Superbase af område. Billede 2 af 2 -->
  <img src="/src/img/sandy_beach_coastline.webp" alt="" class="img_mobile-2">

    

<Banner />
</main>
</Layout>




<style>

/* MOBILE FIRST */ 

main {
display: grid;
grid-template-columns: 1fr;

align-items: center;
margin: 0 auto;   
}

h1 {
  font-size: var(--h1-mobile);
}

h2 {
  font-size: var(--h2-mobile);
}

p {
  font-size: var(--p-mobile);
}

.collage-wrapper {
  display: none;
}

.img_mobile-1,
.img_mobile-2 {
  display: block;
 
  margin: 0 auto;
}

.nature-text,
h1 {
   display: block;

   max-width: 350px;
   margin: 0 auto;
   padding: 25px;
}




  /* DESKTOP 1024PX*/

  @media (min-width: 1024px) {
    main {
      max-width: 1200px;
    }

h1 {
  font-size: var(--h1);
  margin: 0 auto;
}

h2 {
  font-size: var(--h2);
}

p {
  font-size: var(--p);
}


.desktop-section {
  display: flex;
  flex-direction: row;

  justify-content: space-between;
  margin: 0 auto;
  gap: 100px;
}






/* DISPLAY NONE PÅ MOBIL-OPSÆTNING */

.img_mobile-1,
.img_mobile-2 {
    display: none;
}


/* VIS BILLEDER I COLLAGE */


.collage-wrapper {
  display: block;
}

.collage-wrapper {
    position: relative;

    width: 450px;
    height: 500px; /* giver plads til overlap */
  }

  .collage-wrapper img {
    position: absolute;

    width: 100%;
    height: auto;

    border-radius: var(--img_border);
    object-fit: cover;
  }

  .detail-img1 {
    top: 0;
    left: 0;
    z-index: 1;
  }

  .detail-img2 {
    top: 120px;
    left: 80px;
    z-index: 2;
    display: block;
  }

  .detail-img3 {
    top: 240px;
    left: 20px;
    z-index: 3;
    display: block;
  }


}

</style>