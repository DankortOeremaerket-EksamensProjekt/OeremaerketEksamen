---
import "../css/custom.css";
---

<div class="donation">
  <div class="headline">
    <span class="dot"></span>
    <h2 class="desktop">Estimeret donation til den Danske Natur</h2>
    <h2 class="mobile">Donation indtil videre</h2>
  </div>
  <h3>Januar 2026 - Nu</h3>
  <h1>2.918.994,65 KR.</h1>
</div>



<style>
/*   CSS - MOBILE FIRST */


.headline {
  display: flex;
  align-items:first baseline;
  color: var(--white);
}

.dot {
  width: 20px;
  height: 15px;
  background-color: var(--red);
  border-radius: 50%;
  display: inline-block;
  margin-top: -27px;
}

.headline h2 {
  margin: 0;
  color: var(--white);
}


.donation {
  background: none;
  border: none; 

  backdrop-filter:none;
  
  border-radius: var(--btn_border);
  padding: 20px;
  max-width: 350px;

}

h1,
h3 {
  color: var(--white);
  text-align: right;
}
h1{
  font-size: 20px;
  font-weight: 700;
    font-family: "Raleway";
}
h2{
  font-size: var(--h1-mobile);
  font-weight: 600;
}
h3{
font-size: 12px;
font-weight: 700;
}
.desktop{
  display:none;

}
.mobile{display: block;}
 @media (min-width:1024px) {
 .desktop{
  display:block;
 }
 .mobile{
  display:none;
 }
 .donation {
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.25); 

  backdrop-filter: blur(10px);
  
  border-radius: var(--btn_border);
  padding: 20px;
  max-width: 350px;

 }
 .headline {
  display: flex;
  align-items: center;
}
</style>