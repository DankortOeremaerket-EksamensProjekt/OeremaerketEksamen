---
import Layout from "../layouts/Layout.astro";
import ButtonsNav from "../components/Buttons_nav.astro";
import "../css/custom.css";
import Jumpdown from "../assets/jumpdown.svg";
import Piggyback from "../img/girls_piggybacking.webp";
import Smallshop from "../img/small_shop.webp";
import Mobilsti from "../assets/sti_mobil.svg";
---

<Layout>
  <div class="step_2_1">
    <div class="step_tekst">
      <h1>Det er nemt at få et Dankort</h1>
      <p>
        Følg vores nemme step by step guide, så du hurtigt kan komme i gang med
        at støtte både natur og lokal butikker.
      </p>
      <img src={Jumpdown.src} alt="" class="jump_down_button" />
    </div>
    <div class="step_billeder">
      <img src={Smallshop.src} alt="" class="step_pic" id="desktop_billed" />
      <img src={Piggyback.src} alt="" class="step_pic" id="mobil_billed" />
    </div>
  </div>
  <!-- <img src={Mobilsti.src} alt="" class="mobil_sti" /> -->
  <div class="step_by_step_title">
    <h1>3 nemme steps til Dankort</h1>
  </div>
  <div class="step_by_step">
    <div class="step-wrapper">
      <div class="step_venstre" id="step_1">
        <div class="step_v_pic">
          <img src={Piggyback.src} alt="" />
        </div>
        <div class="step_v_tekst">
          <h2>STEP 1</h2>
          <p>
            Hver gang du bruger dit Dankort, donerer vi 1 øre til Den Danske
            Naturfond. Det bliver til mere end 10 millioner kroner hvert år,
          </p>
        </div>
      </div>
      <div class="step_hoejre">
        <div class="step_h_pic" id="step_2">
          <img src={Piggyback.src} alt="" />
        </div>
        <div class="step_h_tekst">
          <h2>STEP 2</h2>
          <p>
            Hver gang du bruger dit Dankort, donerer vi 1 øre til Den Danske
            Naturfond. Det bliver til mere end 10 millioner kroner hvert år,
          </p>
        </div>
      </div>
      <div class="step_venstre" id="step_3">
        <div class="step_v_pic">
          <img src={Piggyback.src} alt="" />
        </div>
        <div class="step_v_tekst">
          <h2>STEP 3</h2>
          <p>
            Hver gang du bruger dit Dankort, donerer vi 1 øre til Den Danske
            Naturfond. Det bliver til mere end 10 millioner kroner hvert år,
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .step_2_1 {
    display: grid;
    grid-template-columns: 1fr 120px;
    align-items: center;
    gap: 0.5rem;
  }
  img {
    border-radius: 25px;
  }
  #desktop_billed {
    display: none;
  }
  #mobil_billed {
    height: 15rem;
    width: auto;
    position: relative;
    overflow: hidden;
  }
  .step_tekst {
    grid-column: 1;
    padding: 1.5rem 1rem 1.5rem 1.5rem;
  }
  h1 {
    font-size: var(--h1-mobil);
  }
  p {
    font-size: var(--p-mobil);
  }
  h2 {
    font-size: var(--h2-mobil);
  }
  .step_billeder {
    position: relative;
    width: 120px;
    height: auto;
    overflow: hidden;
  }

  /*step-by-step*/
  .step_by_step {
    height: fit-content;

    overflow: hidden;
    background-image: url(../assets/mobil_step_baggrund.svg);
  }
  .step-wrapper {
    display: flex;
    flex-direction: column;
    gap: 10rem 0;
  }
  .step_venstre {
    display: flex;
    flex-direction: row;
    transform: translateX(-4rem);
  }
  .step_hoejre {
    display: flex;
    flex-direction: row;
    justify-content: flex-end;
    transform: translateX(4rem);
  }
  .step_v_pic img,
  .step_h_pic img {
    width: 10rem;
    position: relative;
    height: auto;
  }
  .step_v_tekst,
  .step_h_tekst {
    background-color: var(--light-blue);
    border-radius: 25px;
    width: 8rem;
    padding: 1rem;
    height: auto;
  }
  .step_h_tekst {
  }
  .step_h_pic {
    order: 2;
  }
  /* .mobil_sti {
    border-radius: 0px;
    position: absolute;
    height: 48rem;
    left: 50%;
    transform: translateX(-50%);
    top: 60%;
  } */
  .step_by_step_title {
    text-align: center;
    padding: 2rem 0;
  }

  @media (min-width: 800px) {
    .step_2_1 {
      max-width: 1200px;
      padding: 5rem 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      margin: 0 auto;
    }

    #desktop_billed {
      display: block;
      height: 20rem;
    }
    #mobil_billed {
      height: 20rem;
    }
    .step_billeder {
      display: flex;
      flex-direction: row;
      width: 100%;
      height: auto;
    }
    h1 {
      font-size: var(--h1);
    }
    p {
      font-size: var(--p);
    }
    /*step-by-step desktop*/
    .step_by_step {
      display: flex;
      justify-content: center;

      padding: 0 5rem;
      margin: 0 auto;
      background-repeat: repeat;
    }
    .step-wrapper {
      max-width: 1200px;
      width: 100%;
      margin: 2rem 0;
    }
    .step_v_pic img,
    .step_h_pic img {
      width: 15rem;
      position: relative;
      height: auto;
    }
    .step_v_tekst,
    .step_h_tekst {
      width: 15rem;
      padding: 1rem;
      height: auto;
    }
    .step_venstre {
      transform: translateX(0rem);
    }
    .step_hoejre {
      justify-content: flex-end;
      transform: translateX(0rem);
    }

    .jump_down_button {
      width: 3rem;
    }
  }
</style>
