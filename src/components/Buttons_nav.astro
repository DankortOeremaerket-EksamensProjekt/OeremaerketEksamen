---
import "../css/custom.css";
---

<div class="nav_btns">
  <a href="https://dankort.dk/oremaerket" class="nav-link">Vores koncept</a>
  <a href="https://dankort.dk/oremaerket" class="nav-link active">Udforsk områderne</a>
  <a href="https://dankort.dk/oremaerket" class="nav-link">Dankort i 3 trin</a>
</div>

<style>
  .nav_btns {
    top: 0;
    position: sticky;
    z-index: 999;
    display: flex;
    justify-content: center;
    gap: 10px;
  }

  .nav-link {
    background-color: #b4b4b4;
    color: black;
    text-decoration: none;
    font-size: 14px;
    backdrop-filter: blur(90px);
    transition: 0.3s ease;
    padding: 15px 30px;
    border-radius: 25px;
    margin: 10px;
  }

  .nav-link:hover {
    background: #ebebeb;
    cursor: pointer;
  }

  .nav-link.active {
    background: #4a4a4a;
    color: white;
  }

  @media (min-width: 1024px) {
    .nav_btns {
      gap: 50px;
    }
  }
</style>